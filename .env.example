# Kendi Dokümanların ile Sohbet Et — Ortam Değişkenleri
# Bu dosyayı kopyalayıp .env olarak kaydedin:
#   cp .env.example .env
#
# Kök .env  → Docker Compose tarafından okunur
# backend/.env → yerel geliştirme ortamı (uvicorn) tarafından okunur

# ---------------------------------------------------------------
# ZORUNLU
# ---------------------------------------------------------------
# Google AI Studio'dan ücretsiz API anahtarı alın:
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ---------------------------------------------------------------
# İSTEĞE BAĞLI (varsayılanlar uygundur)
# ---------------------------------------------------------------

# Ana LLM modeli (doküman analiz + RAG yanıtları)
DEFAULT_MODEL=gemini-2.5-flash-lite

# Hızlı model (takip soruları ve özetler için)
FAST_MODEL=gemini-1.5-flash

# Embedding modeli — ChromaDB vektör indekslemesi için
EMBEDDING_MODEL=models/gemini-embedding-001

# ChromaDB vektör veritabanı yolu (Docker volume ile yönetilir)
CHROMA_PATH=resource/chroma_db

# Debug çıktısı
DEBUG=false
