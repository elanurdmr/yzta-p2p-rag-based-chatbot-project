# Ortam değişkenleri yapılandırması

# Veritabanı yapılandırması
# SQLite (varsayılan)
DATABASE_URL=sqlite+aiosqlite:///resource/database.db
# MySQL kullanmak için:
# DATABASE_URL=mysql+aiomysql://root:root@localhost/ai-chatkit

# Uygulama yapılandırması
DEBUG=True
APP_NAME=Kendi Dokümanların ile Sohbet Et

# Google Gemini API Anahtarı (zorunlu)
# https://aistudio.google.com/app/apikey adresinden alın
GOOGLE_API_KEY=your_google_api_key_here

# Kullanılacak Gemini modeli
DEFAULT_MODEL=gemini-1.5-flash

# Google Generative AI Embedding modeli
EMBEDDING_MODEL=models/embedding-001

# ChromaDB kalıcı depolama yolu
CHROMA_PATH=resource/chroma_db
